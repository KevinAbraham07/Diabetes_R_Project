cat("Range:", range_value, "\n")
cat("Quartiles:", quartiles, "\n")
cat("Variance:", variance_value, "\n")
cat("Standard Deviation:", std_dev, "\n")
cat("Mean Deviation:", mean_dev, "\n")
sample_mean <- 2.06
population_mean <- 2.0
sample_sd <- 0.141
n <- 51
alpha <- 0.10
t_value <- (sample_mean - population_mean) / (sample_sd / sqrt(n))
p_value <- pt(t_value, df=n-1, lower.tail=FALSE)
cat("t-value:", t_value, "\n")
cat("p-value:", p_value, "\n")
if (p_value < alpha) {
cat("Reject the null hypothesis: The population mean zinc mass exceeds 2.0 g.\n")
} else {
cat("Fail to reject the null hypothesis: No sufficient evidence that the mean exceeds 2.0 g.\n")
}
mean1 <- 48.9
mean2 <- 43.2
sigma1 <- 14.6
sigma2 <- 14.4
n1 <- 125
n2 <- 90
alpha <- 0.05
z_value <- (mean1 - mean2) / sqrt((sigma1^2 / n1) + (sigma2^2 / n2))
p_value <- 1 - pnorm(z_value)
cat("Z-value:", z_value, "\n")
cat("p-value:", p_value, "\n")
if (p_value < alpha) {
cat("Reject the null hypothesis: Doctors in full-time practice live longer than those with academic affiliations.\n")
} else {
cat("Fail to reject the null hypothesis: No sufficient evidence that full-time doctors live longer.\n")
}
p0 <- 0.90
p_hat <- 0.85
n <- 200
alpha <- 0.05
z_value <- (p_hat - p0) / sqrt((p0 * (1 - p0)) / n)
p_value <- 2 * pnorm(z_value, lower.tail=FALSE)
cat("Z-value:", z_value, "\n")
cat("p-value:", p_value, "\n")
if (p_value < alpha) {
cat("Reject the null hypothesis: The company's claim is false.\n")
} else {
cat("Fail to reject the null hypothesis: No strong evidence against the company's claim.\n")
}
observed <- matrix(c(138, 83, 64,
64, 67, 84),
nrow = 2, byrow = TRUE)
rownames(observed) <- c("Democrat", "Republican")
colnames(observed) <- c("Favor", "Indifferent", "Oppose")
chi_test <- chisq.test(observed)
cat("Chi-square value:", chi_test$statistic, "\n")
cat("p-value:", chi_test$p.value, "\n")
alpha <- 0.05
if (chi_test$p.value < alpha) {
cat("Reject the null hypothesis: Political affiliation and opinion on the tax reform bill are not independent.\n")
} else {
cat("Fail to reject the null hypothesis: No sufficient evidence to conclude dependence between political affiliation and opinion.\n")
}
unit_A <- c(14.1, 10.1, 14.7, 13.7, 14.0)
unit_B <- c(14.0, 14.5, 13.7, 12.7, 14.1)
alpha <- 0.10
variance_test <- var.test(unit_A, unit_B)
cat("F-value:", variance_test$statistic, "\n")
cat("p-value:", variance_test$p.value, "\n")
if (variance_test$p.value < alpha) {
cat("Reject the null hypothesis: The two populations do not have the same variance.\n")
} else {
cat("Fail to reject the null hypothesis: No sufficient evidence to conclude a difference in variances.\n")
}
program1 <- c(9, 12, 14, 11, 13)
program2 <- c(10, 6, 9, 9, 10)
program3 <- c(12, 14, 11, 13, 11)
program4 <- c(9, 8, 11, 7, 8)
data <- data.frame(
Performance = c(program1, program2, program3, program4),
Program = factor(rep(c("Program1", "Program2", "Program3", "Program4"), each = 5))
)
anova_result <- aov(Performance ~ Program, data = data)
summary(anova_result)
alpha <- 0.05
if (summary(anova_result)[[1]]["Program", "Pr(>F)"] < alpha) {
cat("Reject the null hypothesis: There is a significant difference between training programs.\n")
} else {
cat("Fail to reject the null hypothesis: No significant difference between training programs.\n")
}
temperature <- c(53, 62, 57, 71, 78, 66, 84, 87, 96, 91, 94, 96)
chirps_per_minute <- c(20, 32, 40, 60, 80, 100, 120, 140, 160, 180, 200, 220)
model <- lm(chirps_per_minute ~ temperature)
summary(model)
cat("Regression Line: y =", coef(model)[1], "+", coef(model)[2], "* x\n")
plot(temperature, chirps_per_minute, main="Temperature vs Chirps per Minute",
xlab="Temperature (F)", ylab="Chirps per Minute", pch=19, col="blue")
abline(model, col="red", lwd=2)
q()
