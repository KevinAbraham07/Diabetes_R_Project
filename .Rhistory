16, 18, 20, 25,
15, 23, 28, 14,
17, 21, 19, 11,
18, 20, 13, 24,
18, 21, 10, 17)
data <- data.frame(Block = blocks, Worker = workers, Yield = yield)
rbd_result <- aov(Yield ~ Worker + Block, data = data)
summary(rbd_result)
par(mfrow = c(2, 2))
plot(rbd_result)
