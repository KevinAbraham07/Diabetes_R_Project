temperature <- c(53, 62, 57, 71, 78, 66, 84, 87, 96, 91, 94, 96)
chirps_per_minute <- c(20, 32, 40, 60, 80, 100, 120, 140, 160, 180, 200, 220)
correlation <- cor(temperature, chirps_per_minute, method = "pearson")
cat("Karl Pearson's Correlation Coefficient:", correlation, "\n")
temperature <- c(53, 62, 57, 71, 78, 66, 84, 87, 96, 91, 94, 96)
chirps_per_minute <- c(20, 32, 40, 60, 80, 100, 120, 140, 160, 180, 200, 220)
model <- lm(chirps_per_minute ~ temperature)
summary(model)
cat("Regression Line: y =", coef(model)[1], "+", coef(model)[2], "* x\n")
plot(temperature, chirps_per_minute, main="Temperature vs Chirps per Minute",col="blue")
abline(model,col="red",lwd=2)
plot(temperature, chirps_per_minute, main="Temperature vs Chirps per Minute",col="blue")
n <- 10
p <- 0.2
q <- 1 - p
P_X1 <- choose(n, 1) * (p^1) * (q^(n-1))
P_X0 <- choose(n, 0) * (p^0) * (q^n)
P_X_leq1 <- P_X0 + P_X1
cat("P(Only 1 family purchases) =", P_X1, "\n")
cat("P(No family purchases) =", P_X0, "\n")
cat("P(Not more than 1 family purchases) =", P_X_leq1, "\n")
# Given data
mu <- 2040  # Mean life of bulbs
sigma <- 60  # Standard deviation
total_bulbs <- 2000
# Function to compute number of bulbs
compute_bulbs <- function(x1, x2 = NULL) {
if (is.null(x2)) {
prob <- 1 - pnorm((x1 - mu) / sigma)  # For P(X > x1)
} else {
prob <- pnorm((x2 - mu) / sigma) - pnorm((x1 - mu) / sigma)  # For P(x1 < X < x2)
}
return(round(prob * total_bulbs))
}
# (i) More than 2150 hours
bulbs_2150 <- compute_bulbs(2150)
# (ii) Less than 1950 hours
bulbs_1950 <- compute_bulbs(1950)
bulbs_1950 <- total_bulbs - bulbs_1950  # Since we need P(X < 1950)
# (iii) More than 1920 but less than 2160 hours
bulbs_1920_2160 <- compute_bulbs(1920, 2160)
# (iv) More than 2150 hours (Same as (i))
bulbs_2150_repeat <- bulbs_2150
cat("Bulbs burning more than 2150 hours:", bulbs_2150, "\n")
cat("Bulbs burning less than 1950 hours:", bulbs_1950, "\n")
cat("Bulbs burning between 1920 and 2160 hours:", bulbs_1920_2160, "\n")
cat("Bulbs burning more than 2150 hours (repeated):", bulbs_2150_repeat, "\n")
mu <- 2040
sigma <- 60
total_bulbs <- 2000
compute_bulbs <- function(x1, x2 = NULL) {
if (is.null(x2)) {
prob <- 1 - pnorm((x1 - mu) / sigma)
} else {
prob <- pnorm((x2 - mu) / sigma) - pnorm((x1 - mu) / sigma)
}
return(round(prob * total_bulbs))
}
bulbs_2150 <- compute_bulbs(2150)
bulbs_1950 <- total_bulbs - compute_bulbs(1950)
bulbs_1920_2160 <- compute_bulbs(1920, 2160)
bulbs_2150_repeat <- bulbs_2150
cat("Bulbs burning more than 2150 hours:", bulbs_2150, "\n")
cat("Bulbs burning less than 1950 hours:", bulbs_1950, "\n")
cat("Bulbs burning between 1920 and 2160 hours:", bulbs_1920_2160, "\n")
cat("Bulbs burning more than 2150 hours (repeated):", bulbs_2150_repeat, "\n")
set.seed(42)
marks <- sample(30:100, 30, replace = TRUE)
mean_value <- mean(marks)
median_value <- median(marks)
mode_value <- as.numeric(names(sort(table(marks), decreasing = TRUE)[1]))
range_value <- max(marks) - min(marks)
quartiles <- quantile(marks)
variance_value <- var(marks)
std_dev <- sd(marks)
mean_dev <- mean(abs(marks - mean_value))
cat("Mean:", mean_value, "\n")
cat("Median:", median_value, "\n")
cat("Mode:", mode_value, "\n")
cat("Range:", range_value, "\n")
cat("Quartiles:", quartiles, "\n")
cat("Variance:", variance_value, "\n")
cat("Standard Deviation:", std_dev, "\n")
cat("Mean Deviation:", mean_dev, "\n")
